{
  "manifest_version": 3,
  "name": "NamaStream",
  "author": "Erm",
  "version": "1.21",
  "description": "Adds a VTuber stream dashboard to your new tabs, showing live and scheduled YouTube streams.",
  "icons": {
    "32": "icon.png",
    "48": "icon48.png",
    "96": "icon96.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "NamaStream@erm.dev",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "New tab Layout",
    "default_popup": "/popup/popup.html"
  },

  "chrome_url_overrides": {
    "newtab": "/newtab/newtab.html"
  },

  "permissions": [
    "storage"
  ]
}
